<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.mapper.NotificationMapper">
    <select id="selectUnreadByUserId" resultType="org.example.entity.Notification">
        SELECT * FROM notification WHERE user_id = #{userId} AND is_read = 0 ORDER BY created_at DESC
    </select>
</mapper>
